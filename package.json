{
  "name": "@pixl/pixl",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.10.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "landing": "turbo dev --filter=@pixl/landing",
    "internal": "turbo dev --filter=@pixl/internal-dashboard",
    "player": "turbo dev --filter=@pixl/player-dashboard",
    "build": "turbo build"
  },
  "packageManager": "bun@1.3.13"
}
