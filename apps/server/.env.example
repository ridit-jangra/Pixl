SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Random long string, used to sign session JWTs
JWT_SECRET=change-this-to-a-long-random-string

HCA_CLIENT_ID=
HCA_CLIENT_SECRET=
HCA_REDIRECT_URI=http://localhost:3000/auth/hackclub/callback

PORT=3000

# Shared secret for the dashboard's admin API (online list, kick). Must match
# the dashboard's ADMIN_API_KEY. Leave empty to disable those endpoints.
ADMIN_API_KEY=

ALLOW_DEMO_LOGIN