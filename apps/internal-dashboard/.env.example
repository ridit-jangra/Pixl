# Same Supabase project the game server uses
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service-role-key

# Slack app (https://api.slack.com/apps):
#  - OAuth & Permissions -> Redirect URLs: <BASE_URL>/api/auth/callback
#  - Bot Token Scopes: chat:write, im:write
#  - Install to workspace, copy the Bot User OAuth Token below
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# Comma-separated Slack member IDs allowed into the dashboard (e.g. U0123ABC,U0456DEF)
ADMIN_SLACK_IDS=

# Comma-separated Slack member IDs allowed to do the FINAL (second) review pass.
# Only these reviewers can approve and credit pixels. If left empty, only owners
# (ADMIN_SLACK_IDS) qualify. For now this is just Gabin.
SECOND_PASS_SLACK_IDS=

# Pixorpheus external DM API , all player-facing DMs are sent through this.
# EXTERNAL_API_KEY must match the x-api-key configured on the DM service.
EXTERNAL_API_KEY=
# Optional override; defaults to https://dashboard.gabintavernier.com/api/external/dm
EXTERNAL_DM_URL=

# Email fallback (Resend) , used when a player has no slack_id or the DM fails.
# Leave empty to disable.
RESEND_API_KEY=
EMAIL_FROM=Pixl <team@pixl.rsvp>

# Long random string for signing session cookies
SESSION_SECRET=

# Where this dashboard runs (used for the OAuth redirect)
BASE_URL=http://localhost:4900

# Live game server admin API (Online tab + kick). ADMIN_API_KEY must match the
# server's env. Leave empty to disable the Online tab's live view.
PIXL_SERVER_URL=
ADMIN_API_KEY=

# Daily review-queue Slack alert (vercel.json cron). Channel ID the dashboard
# bot is invited to; leave empty to disable. CRON_SECRET guards the endpoint.
REVIEW_ALERT_CHANNEL=
CRON_SECRET=
