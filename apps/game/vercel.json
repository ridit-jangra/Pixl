{
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "redirects": [
    { "source": "/shop", "destination": "https://dash.pixl.rsvp/shop", "statusCode": 302 },
    { "source": "/shop/:path*", "destination": "https://dash.pixl.rsvp/shop/:path*", "statusCode": 302 },
    { "source": "/explore", "destination": "https://dash.pixl.rsvp/explore/players", "statusCode": 302 },
    { "source": "/explore/:path*", "destination": "https://dash.pixl.rsvp/explore/:path*", "statusCode": 302 },
    { "source": "/projects", "destination": "https://dash.pixl.rsvp/projects", "statusCode": 302 },
    { "source": "/projects/:path*", "destination": "https://dash.pixl.rsvp/projects/:path*", "statusCode": 302 },
    { "source": "/report", "destination": "https://dash.pixl.rsvp/report", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/((?!vault|quests|timeline|hackatime|fonts|img|pixl).*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
